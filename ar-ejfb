-- Fungsi Pembuat Box Input/Tombol Mini
local function createMiniBox(titleText, placeholder, onAction, changeSignal)
    local Card = Instance.new("Frame", GridFrame)
    Card.BackgroundColor3 = Theme.Card
    Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 4)
    Instance.new("UIStroke", Card).Color = Theme.Stroke

    local lbl = Instance.new("TextLabel", Card)
    lbl.Size = UDim2.new(1, 0, 0, 34)
    lbl.Position = UDim2.new(0, 0, 0, 2)
    lbl.Text = titleText
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 9
    lbl.TextColor3 = Theme.Text
    lbl.TextWrapped = true
    lbl.BackgroundTransparency = 1

    if changeSignal then
        local function upd(v) lbl.Text = titleText .. "\n(" .. tostring(v) .. ")" end
        upd(changeSignal.Value)
        changeSignal.Changed:Connect(upd)
    end

    local box = Instance.new("TextBox", Card)
    box.Size = UDim2.new(1, -12, 0, 26)
    box.Position = UDim2.new(0, 6, 1, -32)
    box.BackgroundColor3 = Theme.Bg
    box.PlaceholderText = placeholder
    box.Text = ""
    box.Font = Enum.Font.Gotham
    box.TextSize = 10
    box.TextColor3 = Theme.Accent
    box.PlaceholderColor3 = Theme.Muted
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 3)

    box.FocusLost:Connect(function()
        if box.Text ~= "" then
            onAction(box.Text)
            box.Text = ""
        end
    end)
end

local function createMiniButton(titleText, btnText, color, onAction)
    local Card = Instance.new("Frame", GridFrame)
