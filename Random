    PriceLabel.TextSize = 10
    PriceLabel.TextColor3 = Theme.TextMuted
    PriceLabel.TextXAlignment = Enum.TextXAlignment.Left
    PriceLabel.BackgroundTransparency = 1

    local BuyBtn = Instance.new("TextButton", ItemCard)
    BuyBtn.Size = UDim2.new(0, 80, 0, 28)
    BuyBtn.Position = UDim2.new(1, -90, 0.5, -14)
    BuyBtn.BackgroundColor3 = Color3.fromRGB(20, 40, 30)
    BuyBtn.Text = "BUY ITEM"
    BuyBtn.Font = Enum.Font.GothamBold
    BuyBtn.TextSize = 10
    BuyBtn.TextColor3 = Theme.Accent
    Instance.new("UICorner", BuyBtn).CornerRadius = UDim.new(0, 4)
    local btnStroke = Instance.new("UIStroke", BuyBtn)
    btnStroke.Color = Theme.Accent

    BuyBtn.MouseButton1Click:Connect(function()
        BuyBtn.Text = "BUYING..."
        BuyBtn.TextColor3 = Theme.TextMuted
        
        -- Jalankan fungsi beli
        pcall(buyCallback)
        
        task.wait(0.5)
        BuyBtn.Text = "BUY ITEM"
        BuyBtn.TextColor3 = Theme.Accent
    end)
end

-- ====================================================================
-- SCANNING SHOP SYSTEM (MENYESUAIKAN GAME YANG DIMAINKAN)
-- ====================================================================

-- 1. Deteksi otomatis letak folder Item Toko di dalam game script
local ShopFolder = game:GetService("ReplicatedStorage"):FindFirstChild("Shop") 
    or game:GetService("ReplicatedStorage"):FindFirstChild("Items")
    or workspace:FindFirstChild("Shop")
    or game:GetService("ReplicatedStorage"):FindFirstChild("ShopItems")

-- 2. Cari RemoteEvent/RemoteFunction yang biasa dipakai game untuk transaksi beli
local BuyRemote = game:GetService("ReplicatedStorage"):FindFirstChild("BuyItem")
    or game:GetService("ReplicatedStorage"):FindFirstChild("PurchaseItem")
    or (ShopFolder and ShopFolder:FindFirstChild("Remote"))

if ShopFolder then
    -- Jika folder shop di dalam game ketemu, buat list otomatis
    for _, item in pairs(ShopFolder:GetChildren()) do
        if item:IsA("Configuration") or item:IsA("Folder") or item:IsA("Tool") then
            -- Cari harga item di dalam objek (biasanya disimpan di IntValue/NumberValue bernama Price atau Cost)
            local priceObj = item:FindFirstChild("Price") or item:FindFirstChild("Cost") or item:FindFirstChild("Value")
            local actualPrice = priceObj and priceObj.Value or "Free/Unknown"
            
            addItemToList(item.Name, actualPrice, function()
                -- LOGIKA EXPLOIT PEMBELIAN:
                -- Mengirim data pembelian ke server game menggunakan RemoteEvent game tersebut
                if BuyRemote and BuyRemote:IsA("RemoteEvent") then
                    BuyRemote:FireServer(item.Name)
                elseif BuyRemote and BuyRemote:IsA("RemoteFunction") then
                    BuyRemote:InvokeServer(item.Name)
                else
                    -- Alternatif jika remote berada langsung di dalam item masing-masing
                    local localRemote = item:FindFirstChildOfClass("RemoteEvent") or item:FindFirstChild("Buy")
                    if localRemote then
                        localRemote:FireServer()
                    else
                        print("Gagal menemukan Remote Pembelian untuk: " .. item.Name)
                    end
                end
            end)
        end
    end
else
    -- JIKA GAME TIDAK MENGGUNAKAN FOLDER STANDARD (MANUAL LIST FALLBACK)
    -- Ini adalah contoh list item tiruan jika skrip tidak berhasil melakukan auto-scan objek game:
    addItemToList("Common Sword", "100 Coins", function()
        -- Ganti bagian ini dengan RemoteEvent game spesifikmu
        print("Membeli Common Sword...")
    end)
    
    addItemToList("Hyper Laser Gun", "5,000 Coins", function()
        print("Membeli Hyper Laser Gun...")
    end)
    
    addItemToList("Speed Boots Nitro", "1,200 Coins", function()
        print("Membeli Speed Boots Nitro...")
    end)
end

