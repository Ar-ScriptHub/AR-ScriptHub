-- 56 & 57. Penanganan Auto Join Team & Auto Spawn
LocalPlayer.CharacterAdding:Connect(function(char)
    if UtilVars.AutoJoinTeam and LocalPlayer.Team.Name ~= UtilVars.TargetTeamName then
        local tObj = game:GetService("Teams"):FindFirstChild(UtilVars.TargetTeamName)
        if tObj then LocalPlayer.Team = tObj end
    end
end)

task.spawn(function()
    while true do
        task.wait(1)
        if UtilVars.AutoSpawn and LocalPlayer.Character then
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then
                -- Meniru trigger tombol deploy ulang game jika dalam kondisi eliminasi
                local spawnEvent = ReplicatedStorage:FindFirstChild("SpawnEvent") or ReplicatedStorage:FindFirstChild("DeployRemote")
                if spawnEvent and spawnEvent:IsA("RemoteEvent") then spawnEvent:FireServer() end
            end
        end
    end
end)

-- 58 & 59. Penanganan Auto Equip Tools & Auto Eat Items
RunService.Stepped:Connect(function()
    if UtilVars.AutoEquip and LocalPlayer.Character then
        local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
        if bp then
            for _, tool in pairs(bp:GetChildren()) do
                if tool:IsA("Tool") then tool.Parent = LocalPlayer.Character end
            end
        end
    end
    
    if UtilVars.AutoEat and LocalPlayer.Character then
        for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and (string.find(string.lower(tool.Name), "food") or string.find(string.lower(tool.Name), "potion") or string.find(string.lower(tool.Name), "eat")) then
                tool:Activate()
            end
        end
    end
end)

