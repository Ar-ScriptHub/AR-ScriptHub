        Box = CreateDraw("Square", {Thickness = 1.5, Filled = false, Color = _G.Config.Theme.Accent, Visible = false}),
        Tracer = CreateDraw("Line", {Thickness = 1, Color = Color3.fromRGB(255, 255, 255), Visible = false}),
