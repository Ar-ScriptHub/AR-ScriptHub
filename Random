        local method = getnamecallmethod()
        local args = {...}
        
        -- Memanipulasi fungsi pencarian target/arah peluru game jika Silent Aim aktif
        if CombatVars.SilentAim and (method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList" or method == "Raycast") then
