-- 62. Penanganan Chat Spammer & 65. Bypass Filter
task.spawn(function()
    while true do
        task.wait(UtilVars.SpamInterval)
        if UtilVars.ChatSpam then
            local finalMsg = UtilVars.SpamMessage
            if UtilVars.BypassChat then
                -- Contoh pengacak karakter sederhana untuk memecah deteksi filter chat Roblox
                finalMsg = string.gsub(finalMsg, "a", "а") -- Mengganti huruf latin ke Cyrillic homoglyph
                finalMsg = string.gsub(finalMsg, "e", "е")
            end
            
            local chatEvent = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
            if chatEvent and chatEvent:IsA("RemoteEvent") then
                chatEvent:FireServer(finalMsg, "All")
            else
                game:GetService("TextChatService").TextChannels.RBXGeneral:SendAsync(finalMsg)
            end
        end
    end
end)

-- 70. Penanganan Jaringan Remote Event Logger Analisator
local oldFireServer
oldFireServer = hookfunction(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
    if UtilVars.RemoteLog then
        local args = {...}
        print("[REMOTE LOGGER] Fired RemoteEvent Name: " .. tostring(self.Name) .. " | Path: " .. tostring(self:GetFullName()))
        if #args > 0 then
            for i, arg in pairs(args) do
                print("   -> Argument [" .. i .. "]: (" .. type(arg) .. ") = " .. tostring(arg))
            end
        end
    end
    return oldFireServer(self, ...)
end))

