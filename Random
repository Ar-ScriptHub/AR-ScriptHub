-- Fungsi untuk membuat tombol pilihan secara otomatis di dalam UI
local function createOptionButton(name, executeCallback)
    local OptionBtn = Instance.new("TextButton", Container)
    OptionBtn.Name = "Option_" .. name
    OptionBtn.Size = UDim2.new(1, -4, 0, 36)
    OptionBtn.BackgroundColor3 = Theme.CardBg
    OptionBtn.BorderSizePixel = 0
    OptionBtn.Font = Enum.Font.GothamMedium
    OptionBtn.Text = "  " .. name
    OptionBtn.TextColor3 = Theme.TextMain
    OptionBtn.TextSize = 11
    OptionBtn.TextXAlignment = Enum.TextXAlignment.Left

    Instance.new("UICorner", OptionBtn).CornerRadius = UDim.new(0, 5)
    local btnStroke = Instance.new("UIStroke", OptionBtn)
    btnStroke.Color = Theme.Stroke

    OptionBtn.MouseButton1Click:Connect(function()
        pcall(executeCallback)
        updateCurrentStatus()
        
        -- Efek visual kilatan warna saat diklik
        OptionBtn.BackgroundColor3 = Theme.Accent
        OptionBtn.TextColor3 = Theme.Bg
        task.wait(0.1)
        OptionBtn.BackgroundColor3 = Theme.CardBg
        OptionBtn.TextColor3 = Theme.TextMain
    end)
end

-- PROSES LOADING PILIHAN
-- Membaca objek target untuk menentukan metode perubahan value yang tepat
if TargetObject:IsA("ValueBase") then
    -- KONDISI 1: Jika SelectedSpoon adalah StringValue (Isinya nama sendok)
    -- Kita buatkan daftar 11 sendok standar atau membaca folder referensi terdekat jika ada
    local presetSpoons = {
        "Default Spoon", "Silver Spoon", "Golden Spoon", "Diamond Spoon", 
        "Ruby Spoon", "Emerald Spoon", "Neon Spoon", "Omega Spoon",
        "Void Spoon", "Brainrot Spoon", "God Spoon"
    }
    
    for _, spoonName in pairs(presetSpoons) do
        createOptionButton(spoonName, function()
            TargetObject.Value = spoonName
        end)
    end
else
    -- KONDISI 2: Jika SelectedSpoon ternyata adalah FOLDER berisi 11 anak objek Value
    local children = TargetObject:GetChildren()
    
    if #children > 0 then
        for _, child in pairs(children) do
            createOptionButton(child.Name, function()
                if child:IsA("BoolValue") then
                    child.Value = true
                elseif child:IsA("StringValue") or child:IsA("IntValue") then
                    -- Ubah sesuai input logika atau ganti statusnya
                    child.Value = not child.Value
                end
            end)
        end
    else
        CurrentValueLabel.Text = "⚠️ Folder is empty or locked by server."
    end
end

print("Spoon Selector GUI Berhasil Dijalankan!")
