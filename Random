-- Helper Function: Mengecek apakah target terhalang dinding
local function IsBehindWall(targetPart)
    if not CombatVars.WallCheck then return false end
    local castParts = Camera:GetPartsObscuringTarget({Camera.CFrame.Position, targetPart.Position}, {LocalPlayer.Character, targetPart.Parent})
    return #castParts > 0
end

-- Helper Function: Mencari target terdekat berdasarkan posisi kursor layar
local function GetClosestPlayerToCursor()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local mousePos = UserInputService:GetMouseLocation()
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            -- Jalankan validasi TeamCheck
            if not CombatVars.TeamCheck or player.Team ~= LocalPlayer.Team then
                local char = player.Character
                if char and char:FindFirstChild(CombatVars.TargetPart) and char:FindFirstChildOfClass("Humanoid") and char.Humanoid.Health > 0 then
                    local targetPart = char[CombatVars.TargetPart]
                    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    
                    if onScreen then
                        local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                        -- Cek apakah target masuk ke dalam lingkaran batas FOV
                        if distance < shortestDistance and distance <= CombatVars.FovRadius then
                            if not IsBehindWall(targetPart) then
                                shortestDistance = distance
                                closestPlayer = player
                            end
                        end
                    end
                end
            end
        end
    end
    return closestPlayer
end

