local mt = getrawmetatable and getrawmetatable(game)
if mt and setreadonly then
    setreadonly(mt, false); local oldNc = mt.__namecall
    mt.__namecall = newcclosure(function(self, ...)
        local m = getnamecallmethod()
        if ComVars.SilentAim and (m == "FindPartOnRay" or m == "Raycast") then
            local t = GetClosestToCursor()
            if t and t.Character and t.Character:FindFirstChild(ComVars.TargetPart) then return t.Character[ComVars.TargetPart], t.Character[ComVars.TargetPart].Position, Vector3.new(0,0,0) end
        end
        return oldNc(self, ...)
    end)
    setreadonly(mt, true)
end

