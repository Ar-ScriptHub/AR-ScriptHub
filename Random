-- ====================================================================
-- AR SCRIPT HUB - FREECAM EXTENSION (ADD-ON SYSTEM)
-- ====================================================================
local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local SafeGuiTarget = Player:FindFirstChildOfClass("PlayerGui") or Player:WaitForChild("PlayerGui", 5)
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

-- 1. CARI PORT UI DARI SCRIPT UTAMA
local MainGui = SafeGuiTarget:FindFirstChild("AR_Script_Hub")
if not MainGui then
    warn("AR Script Hub utama tidak ditemukan! Jalankan script utama terlebih dahulu.")
    return
end

local MainContentFrame = MainGui:FindFirstChild("MainContentFrame", true)
local PlayerPage = MainContentFrame and MainContentFrame:FindFirstChild("PlayerPage")
local LeftColumn = PlayerPage and PlayerPage:FindFirstChild("LeftColumn")

-- Cari Card Fly Control (Card nomor 1 di Left Column)
local flyCard = nil
if LeftColumn then
    for _, child in pairs(LeftColumn:GetChildren()) do
        local ttl = child:FindFirstChildOfClass("TextLabel")
        if ttl and ttl.Text == "FLY CONTROL" then
            flyCard = child:FindFirstChildOfClass("Frame") -- Ini container ui layoutnya
            break
        end
    end
end

if not flyCard then
    warn("Card Fly Control tidak ditemukan!")
    return
end

-- 2. CONFIG & STATE MANAGEMENT UNTUK FREECAM
local FreecamConfig = {
    Active = false,
    Speed = 10
}

local camera = workspace.CurrentCamera
local freecamRenderConn = nil
local savedCameraType = camera.CameraType

-- 3. FREECAM ENGINE CORE
local function handleFreecamEngine(active)
    FreecamConfig.Active = active
    
    if active then
        -- Simpan tipe kamera awal & kunci karakter
        savedCameraType = camera.CameraType
        camera.CameraType = Enum.CameraType.Scriptable
        
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            Player.Character.HumanoidRootPart.Anchored = true
        end
        
        -- Loop Pergerakan Kamera (RenderStepped)
        freecamRenderConn = RunService.RenderStepped:Connect(function(dt)
            if not FreecamConfig.Active then return end
            
            local camCF = camera.CFrame
            local moveVector = Vector3.new(0, 0, 0)
            
            -- Deteksi Input Keyboard
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + camCF.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - camCF.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - camCF.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + camCF.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveVector = moveVector + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveVector = moveVector - Vector3.new(0, 1, 0) end
            
            if moveVector.Magnitude > 0 then
                camera.CFrame = camCF + (moveVector.Unit * FreecamConfig.Speed * dt * 10)
            end
        end)
    else
        -- Matikan Freecam & Kembalikan Karakter
        if freecamRenderConn then
            freecamRenderConn:Disconnect()
            freecamRenderConn = nil
        end
        
        camera.CameraType = savedCameraType
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            Player.Character.HumanoidRootPart.Anchored = false
        end
    end
end

-- 4. INJECT COMPONENT BARU KE UI ASLI LU (MENIRU DESIGN LANGUAGE LU)
-- Mengambil tema warna dari asset asli (pcall aman)
local Theme = {
    Bg = Color3.fromRGB(12, 10, 24),
    Stroke = Color3.fromRGB(56, 52, 92),
    Accent = Color3.fromRGB(115, 170, 255),
    TextMain = Color3.fromRGB(245, 245, 255),
    TextMuted = Color3.fromRGB(140, 145, 175)
}

-- Buat Toggle Freecam
local holderToggle = Instance.new("Frame", flyCard)
holderToggle.Size = UDim2.new(1, 0, 0, 24)
holderToggle.BackgroundTransparency = 1
holderToggle.LayoutOrder = 4 -- Ditaruh di paling bawah Fly Control

local lblToggle = Instance.new("TextLabel", holderToggle)
lblToggle.Text = "Freecam Mode"
lblToggle.Size = UDim2.new(1, -40, 1, 0)
lblToggle.Font = Enum.Font.GothamMedium
lblToggle.TextColor3 = Theme.TextMain
lblToggle.TextSize = 12
lblToggle.TextXAlignment = Enum.TextXAlignment.Left
lblToggle.BackgroundTransparency = 1

local trackToggle = Instance.new("TextButton", holderToggle)
trackToggle.Size = UDim2.new(0, 32, 0, 16)
trackToggle.Position = UDim2.new(1, -32, 0.5, -8)
trackToggle.BackgroundColor3 = Theme.Bg
trackToggle.Text = ""
Instance.new("UICorner", trackToggle).CornerRadius = UDim.new(0, 8)
local tStr = Instance.new("UIStroke", trackToggle)
tStr.Color = Theme.Stroke

local knobToggle = Instance.new("Frame", trackToggle)
knobToggle.Size = UDim2.new(0, 10, 0, 10)
knobToggle.Position = UDim2.new(0, 3, 0.5, -5)
knobToggle.BackgroundColor3 = Theme.TextMuted
Instance.new("UICorner", knobToggle).CornerRadius = UDim.new(0, 5)

trackToggle.MouseButton1Click:Connect(function()
    local nextState = not FreecamConfig.Active
    TweenService:Create(knobToggle, TweenInfo.new(0.08), {Position = UDim2.new(0, nextState and 19 or 3, 0.5, -5)}):Play()
    TweenService:Create(trackToggle, TweenInfo.new(0.08), {BackgroundColor3 = nextState and Theme.Accent or Theme.Bg}):Play()
    tStr.Color = nextState and Theme.Accent or Theme.Stroke
    handleFreecamEngine(nextState)
end)

-- Buat Slider Kecepatan Freecam
local holderSlider = Instance.new("Frame", flyCard)
holderSlider.Size = UDim2.new(1, 0, 0, 38)
holderSlider.BackgroundTransparency = 1
holderSlider.LayoutOrder = 5

local lblSlider = Instance.new("TextLabel", holderSlider)
lblSlider.Text = "Freecam Speed Costumization"
lblSlider.Size = UDim2.new(0.65, 0, 0, 14)
lblSlider.Font = Enum.Font.GothamMedium
lblSlider.TextColor3 = Theme.TextMain
lblSlider.TextSize = 11
lblSlider.TextXAlignment = Enum.TextXAlignment.Left
lblSlider.BackgroundTransparency = 1

local inputBox = Instance.new("TextBox", holderSlider)
inputBox.Size = UDim2.new(0, 36, 0, 16)
inputBox.Position = UDim2.new(1, -36, 0, 0)
inputBox.BackgroundColor3 = Theme.Bg
inputBox.Font = Enum.Font.GothamBold
inputBox.Text = tostring(FreecamConfig.Speed)
inputBox.TextColor3 = Theme.Accent
inputBox.TextSize = 10
Instance.new("UICorner", inputBox).CornerRadius = UDim.new(0, 4)
local bStr = Instance.new("UIStroke", inputBox)
bStr.Color = Theme.Stroke

local trackSlider = Instance.new("Frame", holderSlider)
trackSlider.Size = UDim2.new(1, 0, 0, 4)
trackSlider.Position = UDim2.new(0, 0, 1, -4)
trackSlider.BackgroundColor3 = Theme.Stroke
Instance.new("UICorner", trackSlider).CornerRadius = UDim.new(0, 2)

local fillSlider = Instance.new("Frame", trackSlider)
local min, max = 1, 50
local startPerc = math.clamp((FreecamConfig.Speed - min) / (max - min), 0, 1)
fillSlider.Size = UDim2.new(startPerc, 0, 1, 0)
fillSlider.BackgroundColor3 = Theme.Accent
Instance.new("UICorner", fillSlider).CornerRadius = UDim.new(0, 2)

local knobSlider = Instance.new("Frame", trackSlider)
knobSlider.Size = UDim2.new(0, 10, 0, 10)
knobSlider.Position = UDim2.new(startPerc, -5, 0.5, -5)
knobSlider.BackgroundColor3 = Theme.TextMain
Instance.new("UICorner", knobSlider).CornerRadius = UDim.new(1, 0)

local dragTrigger = Instance.new("ImageButton", knobSlider)
dragTrigger.Size = UDim2.new(2, 0, 2, 0)
dragTrigger.Position = UDim2.new(-0.5, 0, -0.5, 0)
dragTrigger.BackgroundTransparency = 1

local function refreshSlider(value)
    local clamped = math.clamp(value, min, max)
    FreecamConfig.Speed = clamped
    local perc = (clamped - min) / (max - min)
    fillSlider.Size = UDim2.new(perc, 0, 1, 0)
    knobSlider.Position = UDim2.new(perc, -5, 0.5, -5)
    inputBox.Text = tostring(clamped)
end

local sliding = false
dragTrigger.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = true end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end
end)
UserInputService.InputChanged:Connect(function(input)
    if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local relX = input.Position.X - trackSlider.AbsolutePosition.X
        local perc = math.clamp(relX / trackSlider.AbsoluteSize.X, 0, 1)
        refreshSlider(math.round(min + (perc * (max - min))))
    end
end)
inputBox.FocusLost:Connect(function()
    local num = tonumber(inputBox.Text)
    refreshSlider(num or min)
end)

print("AR Hub Extension: Fitur Freecam berhasil disuntikkan!")
