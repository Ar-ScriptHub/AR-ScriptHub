-- [[ 99 Nights in the Forest - Bring All Items dengan UI Toggle ]]
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- Variabel status untuk mengontrol Loop Toggle
local _G = _G or {}
_G.BringAllEnabled = false

-- ==========================================
-- 1. PEMBUATAN UI SIMPEL (GUI)
-- ==========================================

-- Hapus UI lama jika script dijalankan ulang agar tidak menumpuk
local existingGui = LocalPlayer:WaitForChild("PlayerGui"):FindFirstChild("SimpleBringAllUI")
if existingGui then existingGui:Destroy() end

-- Membuat ScreenGui baru
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "SimpleBringAllUI"
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

-- Membuat Tombol Toggle (Button)
local ToggleButton = Instance.new("TextButton")
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0, 150, 0, 40) -- Ukuran tombol (lebar 150, tinggi 40)
ToggleButton.Position = UDim2.new(0, 20, 0, 20) -- Posisi di pojok kiri atas layar
ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Merah saat OFF
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 16
ToggleButton.Text = "Bring All: OFF"

-- Membuat sudut tombol menjadi melengkung/smooth
local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = ToggleButton

-- ==========================================
-- 2. LOGIKA FITUR BRING ALL ITEMS
-- ==========================================

local function bringAllItems()
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    
    if not rootPart then return end

    local targets = {}
    local dropFolder = Workspace:FindFirstChild("Drops") or Workspace:FindFirstChild("DroppedItems") or Workspace:FindFirstChild("Debris")
    
    if dropFolder then
        targets = dropFolder:GetChildren()
    else
        targets = Workspace:GetChildren()
    end

    for _, object in pairs(targets) do
        -- Memastikan objek adalah item/model dan bukan monster atau pemain lain
        if object:IsA("Model") and (object:FindFirstChild("Handle") or object:FindFirstChildWhichIsA("BasePart")) then
            local part = object:FindFirstChild("Handle") or object:FindFirstChildWhichIsA("BasePart")
            
            if part and not object:FindFirstChild("Humanoid") then
                part.CFrame = rootPart.CFrame + Vector3.new(0, 1, 0)
            end
        end
    end
end

-- Loop otomatis yang berjalan di latar belakang selama status "Enabled" bernilai TRUE
task.spawn(function()
    while true do
        if _G.BringAllEnabled then
            bringAllItems()
        end
        task.wait(1) -- Berhenti sejenak selama 1 detik sebelum menarik item lagi (mencegah lag)
    end
end)

-- ==========================================
-- 3. INTERAKSI TOMBOL (EVENT LISTENER)
-- ==========================================

ToggleButton.MouseButton1Click:Connect(function()
    -- Mengubah status ON/OFF setiap kali tombol diklik
    _G.BringAllEnabled = not _G.BringAllEnabled
    
    if _G.BringAllEnabled then
        ToggleButton.Text = "Bring All: ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Berubah jadi hijau saat ON
        print("Fitur Bring All Items DIAKTIFKAN.")
    else
        ToggleButton.Text = "Bring All: OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Kembali jadi merah saat OFF
        print("Fitur Bring All Items DIMATIKAN.")
    end
end)
