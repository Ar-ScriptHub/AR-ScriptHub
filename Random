-- Fungsi Geser UI
local function makeDraggable(frame, handle)
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true dragStart = input.Position startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    handle.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end
makeDraggable(MainFrame, Header)

-- Logika Pengiriman Parameter ke Server
TestBtn.MouseButton1Click:Connect(function()
    if not TargetRemote then 
        warn("Cannot execute: Remote does not exist.")
        return 
    end
    
    local argumentValue = ItemInput.Text
    if argumentValue == "" then
        ItemInput.PlaceholderText = "Please enter a valid item string!"
        return
    end
    
    TestBtn.Text = "SENDING..."
    TestBtn.Active = false
    
    -- Menyesuaikan secara otomatis apakah objek berupa RemoteEvent atau RemoteFunction
    local success, err = pcall(function()
        if TargetRemote:IsA("RemoteEvent") then
            -- Mengirim argumen berupa string nama item ke server
            TargetRemote:FireServer(argumentValue)
            print("Fired RemoteEvent with argument: " .. tostring(argumentValue))
        elseif TargetRemote:IsA("RemoteFunction") then
            -- Memanggil server dan menunggu nilai kembalian (return)
            local response = TargetRemote:InvokeServer(argumentValue)
            print("Invoked RemoteFunction. Server Response: ", response)
        else
            print("Object found but it is not a RemoteEvent or RemoteFunction.")
        end
    end)
    
    if not success then
        print("Error during remote execution: ", err)
    end
    
    task.wait(0.5)
    TestBtn.Text = "EXECUTE REMOTE CALL"
    TestBtn.Active = true
end)

