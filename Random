    if not hum or not root then return end
    
    if MovVars.WalkSpeedToggle then hum.WalkSpeed = MovVars.WalkSpeedVal end
    if MovVars.JumpPowerToggle then hum.UseJumpPower = true; hum.JumpPower = MovVars.JumpPowerVal end
    if MovVars.HipHeightToggle then hum.HipHeight = MovVars.HipHeightVal end
    hum.AutoRotate = MovVars.AutoRotate
    if MovVars.PlatformStandToggle then hum.PlatformStand = true end
    if MovVars.SwimInAir then hum:ChangeState(Enum.HumanoidStateType.Swimming) end
    if MovVars.AntiRagdoll then
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    end
    if MovVars.InfOxygen and char:FindFirstChild("DrowningScript") then char.DrowningScript.Disabled = true end
    
    if MovVars.FlyToggle then
        local bv = root:FindFirstChild("FlyBV") or Instance.new("BodyVelocity", root)
        local bg = root:FindFirstChild("FlyBG") or Instance.new("BodyGyro", root)
