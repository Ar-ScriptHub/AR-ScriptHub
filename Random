-- AUTOMATIC GAME SCANNER ENGINE (MENCARI NAMA SENJATA ASLI)
-- ====================================================================

-- Skrip akan otomatis mendeteksi folder penyimpanan aset sendok asli di ReplicatedStorage
local GameSpoonFolder = ReplicatedStorage:FindFirstChild("Spoons") 
    or ReplicatedStorage:FindFirstChild("SpoonShop") 
    or ReplicatedStorage:FindFirstChild("Items") 
    or ReplicatedStorage:FindFirstChild("Weapons")

if GameSpoonFolder then
    -- KONDISI 1: Folder Aset Ditemukan! Mengambil nama asli dari objek game
    local spoonList = GameSpoonFolder:GetChildren()
    
    for index, obj in pairs(spoonList) do
        -- Membuat tombol berdasarkan nama asli objek dan urutan indeks angkanya
        createOptionButton(obj.Name, index)
    end
else
    -- KONDISI 2: Jika letak folder aset disembunyikan/nama foldernya berbeda jauh,
    -- Skrip menggunakan loop angka 1 sampai 15 secara aman agar kamu tetap bisa mengganti ID-nya langsung di UI
    for i = 1, 15 do
        createOptionButton("Spoon ID Option", i)
    end
    CurrentValueLabel.Text = "⚠️ Folder aset tidak terdeteksi. Menggunakan mode ID manual."
end

