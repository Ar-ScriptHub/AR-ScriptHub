-- Deteksi global Remote Event pembelian (Cari di seluruh ReplicatedStorage)
local GlobalBuyRemote = nil
for _, obj in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
    if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
        local lowerName = string.lower(obj.Name)
        if string.find(lowerName, "buy") or string.find(lowerName, "purchase") or string.find(lowerName, "shop") or string.find(lowerName, "buyitem") then
            GlobalBuyRemote = obj
            break
        end
    end
end

-- Fungsi scan isi dari suatu kontainer/folder secara mendalam
local function scanContainer(folder)
    if not folder then return end
    for _, item in pairs(folder:GetChildren()) do
        -- Cek apakah objek ini dicurigai sebagai Item Toko (Punya Value bernama Price, Cost, atau Cash)
        local priceObj = item:FindFirstChild("Price") or item:FindFirstChild("Cost") or item:FindFirstChild("Value") or item:FindFirstChild("PriceValue")
        
        if priceObj and (priceObj:IsA("IntValue") or priceObj:IsA("NumberValue")) then
            addItemToList(item.Name, priceObj.Value, function()
                if GlobalBuyRemote then
                    if GlobalBuyRemote:IsA("RemoteEvent") then
                        GlobalBuyRemote:FireServer(item.Name)
                    elseif GlobalBuyRemote:IsA("RemoteFunction") then
                        GlobalBuyRemote:InvokeServer(item.Name)
                    end
                else
                    -- Jika remote global tidak ada, cari remote internal di dalam item sendiri
                    local internalRemote = item:FindFirstChildOfClass("RemoteEvent") or item:FindFirstChild("Buy") or item:FindFirstChild("Purchase")
                    if internalRemote and internalRemote:IsA("RemoteEvent") then
                        internalRemote:FireServer()
                    end
                end
            end)
        -- Jika berbentuk struktur Folder/Configuration Toko standar
        elseif item:IsA("Folder") and (string.find(string.lower(item.Name), "shop") or string.find(string.lower(item.Name), "item")) then
            scanContainer(item)
        end
    end
end

