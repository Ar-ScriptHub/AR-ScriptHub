        hum.SeatPart.MaxSpeed = MovVars.VehicleSpeedVal
        hum.SeatPart.Velocity = hum.SeatPart.CFrame.LookVector * (hum.SeatPart.Throttle * MovVars.VehicleSpeedVal)
    end
